  id                   String                 @id @default(uuid()) @db.Uuid
  orderId              String                 @unique @map("order_id") @db.Uuid
  grossAmount          Int                    @map("gross_amount")
  commissionAmount     Int                    @map("commission_amount")
  payoutAmount         Int                    @map("payout_amount")
  payoutMethod         SettlementPayoutMethod @map("payout_method")
  payoutStatus         SettlementPayoutStatus @map("payout_status")
  payoutRef            String?                @map("payout_ref")
  payoutEvidenceFileId String?                @map("payout_evidence_file_id") @db.Uuid
  payoutAt             DateTime?              @map("payout_at")
  status               String
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  order              Order @relation(fields: [orderId], references: [id])
  payoutEvidenceFile File? @relation(fields: [payoutEvidenceFileId], references: [id])

  @@index([payoutStatus])
  @@map("settlements")
}



model SystemConfig {
  id          String                @id @default(uuid()) @db.Uuid
  key         String                @unique
  valueType   SystemConfigValueType @map("value_type")
  value       String
  scope       SystemConfigScope
  version     Int                   @default(1)
  updatedById String?               @map("updated_by") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  updatedBy User? @relation("SystemConfig_UpdatedBy", fields: [updatedById], references: [id])

  @@map("system_configs")
}

model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @map("idempotency_key")
  scope        String
  userId       String   @map("user_id") @db.Uuid
  requestHash  String?  @map("request_hash")
  status       String
  responseJson Json?    @map("response_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([key, scope, userId])
  @@index([scope])
  @@map("idempotency_keys")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id") @db.Uuid
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  requestId   String?  @map("request_id")
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation("AuditLog_Actor", fields: [actorUserId], references: [id])

  @@index([targetType, targetId])
  @@map("audit_logs")
}

model RbacRole {
  id            String   @id
  name          String
  description   String?
  permissionIds Json?    @map("permission_ids_json")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  userRoles RbacUserRole[]

  @@map("rbac_roles")
}

model RbacUserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User     @relation(fields: [userId], references: [id])
  role RbacRole @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
  @@map("rbac_user_roles")
}

model AiParseResult {
  id           String        @id @default(uuid()) @db.Uuid
  contentType  AiContentType @map("content_type")
  contentId    String        @map("content_id") @db.Uuid
  summaryPlain String?       @map("summary_plain")
  featuresPlain String?      @map("features_plain")
  keywordsJson Json?         @map("keywords_json")
  confidence   Float         @default(0)
  modelVersion String?       @map("model_version")
  status       AiParseStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  feedbacks AiParseFeedback[]

  @@index([contentType, contentId])
  @@index([status, createdAt])
  @@map("ai_parse_results")
}

model AiParseFeedback {
  id            String                   @id @default(uuid()) @db.Uuid
  parseResultId String                   @map("parse_result_id") @db.Uuid
  actorUserId   String?                  @map("actor_user_id") @db.Uuid
  actorType     AiParseFeedbackActorType @map("actor_type")
  score         Int
  reasonTagsJson Json?                   @map("reason_tags_json")
  comment       String?
  createdAt     DateTime                 @default(now()) @map("created_at")

  parseResult AiParseResult @relation(fields: [parseResultId], references: [id])
  actor       User?         @relation("AiParseFeedback_Actor", fields: [actorUserId], references: [id])

  @@index([parseResultId, createdAt])
  @@map("ai_parse_feedbacks")
}

model AlertEvent {
  id          String          @id @default(uuid()) @db.Uuid
  type        String
  severity    AlertSeverity
  channel     AlertChannel
  status      AlertStatus
  targetType  AlertTargetType? @map("target_type")
  targetId    String?         @map("target_id") @db.Uuid
  message     String?
  triggeredAt DateTime        @map("triggered_at")
  sentAt      DateTime?       @map("sent_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([status, triggeredAt])
  @@index([targetType, targetId])
  @@map("alert_events")
}

model PatentMaintenanceSchedule {
  id             String                   @id @default(uuid()) @db.Uuid
  patentId       String                   @map("patent_id") @db.Uuid
  yearNo         Int                      @map("year_no")
  dueDate        DateTime                 @map("due_date") @db.Date
  gracePeriodEnd DateTime?                @map("grace_period_end") @db.Date
  status         PatentMaintenanceStatus  @default(DUE)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  patent Patent @relation(fields: [patentId], references: [id])
  tasks  PatentMaintenanceTask[]
  orders PatentMaintenanceOrder[]

  @@unique([patentId, yearNo])
  @@index([status, dueDate])
  @@map("patent_maintenance_schedules")
}

model PatentMaintenanceTask {
  id               String                     @id @default(uuid()) @db.Uuid
  scheduleId       String                     @map("schedule_id") @db.Uuid
  assignedCsUserId String?                    @map("assigned_cs_user_id") @db.Uuid
  status           PatentMaintenanceTaskStatus @default(OPEN)
  note             String?
  evidenceFileId   String?                    @map("evidence_file_id") @db.Uuid
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  schedule       PatentMaintenanceSchedule @relation(fields: [scheduleId], references: [id])
  assignedCsUser User?                     @relation("PatentMaintenanceTask_Assignee", fields: [assignedCsUserId], references: [id])
  evidenceFile   File?                     @relation("PatentMaintenanceTask_Evidence", fields: [evidenceFileId], references: [id])

  @@index([scheduleId, status])
  @@index([assignedCsUserId])
  @@map("patent_maintenance_tasks")
}

model PatentMaintenanceOrder {
  id                  String                          @id @default(uuid()) @db.Uuid
  scheduleId          String                          @map("schedule_id") @db.Uuid
  applicantUserId     String                          @map("applicant_user_id") @db.Uuid
  assignedCsUserId    String?                         @map("assigned_cs_user_id") @db.Uuid
  status              PatentMaintenanceOrderStatus    @default(REQUESTED)
  paymentChannel      PatentMaintenancePaymentChannel? @map("payment_channel")
  officialFeeFen      Int                             @default(0) @map("official_fee_fen")
  lateFeeFen          Int                             @default(0) @map("late_fee_fen")
  serviceFeeFen       Int                             @default(0) @map("service_fee_fen")
  totalAmountFen      Int                             @default(0) @map("total_amount_fen")
  paymentDeadline     DateTime?                       @map("payment_deadline")
  paidAt              DateTime?                       @map("paid_at")
  executedAt          DateTime?                       @map("executed_at")
  receiptIssuedAt     DateTime?                       @map("receipt_issued_at")
  officialSubmissionNo String?                        @map("official_submission_no")
  officialReceiptNo   String?                         @map("official_receipt_no")
  paymentTxnNo        String?                         @map("payment_txn_no")
  officialReceiptFileId String?                       @map("official_receipt_file_id") @db.Uuid
  reconcileStatus     PatentMaintenanceReconcileStatus @default(PENDING) @map("reconcile_status")
  reconcileNote       String?                         @map("reconcile_note")
  closeNote           String?                         @map("close_note")
  createdAt           DateTime                        @default(now()) @map("created_at")
  updatedAt           DateTime                        @updatedAt @map("updated_at")

  schedule            PatentMaintenanceSchedule       @relation(fields: [scheduleId], references: [id])
  applicantUser       User                            @relation("PatentMaintenanceOrder_Applicant", fields: [applicantUserId], references: [id])
  assignedCsUser      User?                           @relation("PatentMaintenanceOrder_Assignee", fields: [assignedCsUserId], references: [id])
  officialReceiptFile File?                           @relation("PatentMaintenanceOrder_ReceiptFile", fields: [officialReceiptFileId], references: [id])
  events              PatentMaintenanceOrderEvent[]

  @@index([scheduleId, status])
  @@index([applicantUserId, createdAt])
  @@index([assignedCsUserId, status])
  @@map("patent_maintenance_orders")
}

model PatentMaintenanceOrderEvent {
  id         String                       @id @default(uuid()) @db.Uuid
  orderId    String                       @map("order_id") @db.Uuid
  actorUserId String?                     @map("actor_user_id") @db.Uuid
  eventType  PatentMaintenanceOrderEventType @map("event_type")
  fromStatus PatentMaintenanceOrderStatus? @map("from_status")
  toStatus   PatentMaintenanceOrderStatus @map("to_status")
  note       String?
  payloadJson Json?                       @map("payload_json")
  createdAt  DateTime                     @default(now()) @map("created_at")

  order     PatentMaintenanceOrder @relation(fields: [orderId], references: [id])
  actorUser User?                  @relation("PatentMaintenanceOrderEvent_Actor", fields: [actorUserId], references: [id])

  @@index([orderId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("patent_maintenance_order_events")
}
