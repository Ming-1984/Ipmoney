generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  seller
  cs
  operator
  finance
  admin
}

enum RegionLevel {
  PROVINCE
  CITY
  DISTRICT
}

enum VerificationType {
  PERSON
  COMPANY
  ACADEMY
  GOVERNMENT
  ASSOCIATION
  TECH_MANAGER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TechManagerBadgeCategory {
  HONOR
  STATUS
}

enum TechManagerBadgeSource {
  ADMIN_MANUAL
  ADMIN_BATCH
  IMPORT
  MIGRATION
}

enum PatentType {
  INVENTION
  UTILITY_MODEL
  DESIGN
}

enum PatentSourcePrimary {
  USER
  ADMIN
  PROVIDER
}

enum ContentSource {
  USER
  PLATFORM
  ADMIN
}

enum PatentIdentifierType {
  APPLICATION
  PATENT
  PUBLICATION
}

enum ClassificationSystem {
  IPC
  LOC
  CPC
}

enum PatentPartyRole {
  APPLICANT
  INVENTOR
  ASSIGNEE
}

enum FileOwnerScope {
  LISTING
  ACHIEVEMENT
  CASE
  REFUND_REQUEST
  INVOICE
  USER
  USER_VERIFICATION
  MESSAGE
}

enum FileModerationStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum ListingTradeMode {
  ASSIGNMENT
  LICENSE
}

enum LicenseMode {
  EXCLUSIVE
  SOLE
  NON_EXCLUSIVE
}

enum PriceType {
  FIXED
  NEGOTIABLE
}

enum AuditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  OFF_SHELF
  SOLD
}

enum ContentStatus {
  DRAFT
  ACTIVE
  OFF_SHELF
}

enum ContentMediaType {
  IMAGE
  VIDEO
  FILE
}

enum AchievementMaturity {
  CONCEPT
  PROTOTYPE
  PILOT
  MASS_PRODUCTION
  COMMERCIALIZED
  OTHER
}

enum FeaturedLevel {
  NONE
  CITY
  PROVINCE
}

enum PledgeStatus {
  NONE
  PLEDGED
  UNKNOWN
}

enum ExistingLicenseStatus {
  NONE
  EXCLUSIVE
  SOLE
  NON_EXCLUSIVE
  UNKNOWN
}

enum ListingMediaType {
  IMAGE
  FILE
}


enum ListingAuditAction {
  APPROVE
  REJECT
}

enum ConsultChannel {
  WECHAT_CS
  PHONE
  FORM
}

enum ConversationMessageType {
  TEXT
  EMOJI
  IMAGE
  FILE
  SYSTEM
}

enum ConversationContentType {
  LISTING
  ACHIEVEMENT
  TECH_MANAGER
  SUPPORT
  DISPUTE
  MAINTENANCE
}

enum ContractStatus {
  WAIT_UPLOAD
  WAIT_CONFIRM
  AVAILABLE
}

enum NotificationKind {
  system
  cs
}

enum CommentContentType {
  LISTING
  ACHIEVEMENT
}

enum ContentEventType {
  VIEW
  FAVORITE
  CONSULT
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum PaymentType {
  DEPOSIT
  FINAL
  REFUND
  PAYOUT
}

enum PaymentChannel {
  WECHAT
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDING
  REFUNDED
}

enum CaseType {
  FOLLOWUP
  REFUND
  DISPUTE
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
}

enum MilestoneName {
  CONTRACT_SIGNED
  TRANSFER_SUBMITTED
  TRANSFER_COMPLETED
}

enum SettlementPayoutMethod {
  MANUAL
  WECHAT
}

enum SettlementPayoutStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum SystemConfigValueType {
  INT
  DECIMAL
  STRING
  JSON
  BOOL
}

enum SystemConfigScope {
  GLOBAL
  TENANT
}

enum AiContentType {
  LISTING
  ACHIEVEMENT
}

enum AiParseStatus {
  ACTIVE
  REVIEW_REQUIRED
  REPLACED
}

enum AiParseFeedbackActorType {
  USER
  ADMIN
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AlertChannel {
  SMS
  EMAIL
  IN_APP
}

enum AlertStatus {
  PENDING
  SENT
  ACKED
  SUPPRESSED
}

enum AlertTargetType {
  PATENT
  ORDER
  LISTING
  ACHIEVEMENT
  AI_PARSE
  IMPORT
  PAYMENT
  REFUND
  SYSTEM
}

enum PatentMaintenanceStatus {
  DUE
  PAID
  OVERDUE
  WAIVED
}

enum PatentMaintenanceTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum PatentMaintenanceOrderStatus {
  REQUESTED
  QUOTED
  AWAITING_PAYMENT
  PAID
  EXECUTING
  RECEIPT_UPLOADED
  RECONCILED
  CLOSED
  CANCELLED
}

enum PatentMaintenancePaymentChannel {
  WECHAT
  OFFLINE_BANK
  OFFLINE_OTHER
}

enum PatentMaintenanceReconcileStatus {
  PENDING
  MATCHED
  MISMATCHED
}

enum PatentMaintenanceOrderEventType {
  CREATED
  QUOTE_UPDATED
  PAYMENT_CONFIRMED
  EXECUTION_SUBMITTED
  RECEIPT_UPLOADED
  RECONCILED
  CLOSED
  CANCELLED
  UPDATED
}

enum ListingJobStatus {
  PENDING
  RUNNING
  PAUSED
  SUCCEEDED
  FAILED
}

enum ListingBatchAction {
  APPROVE
  REJECT
  PUBLISH
  OFF_SHELF
}

enum ListingBatchItemStatus {
  PENDING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum ListingImportDuplicatePolicy {
  SKIP
  OVERWRITE
}

enum ListingImportRowStatus {
  PENDING
  VALID
  INVALID
  SUCCEEDED
  FAILED
  SKIPPED
}

enum ConsultationRouting {
  PLATFORM
  OWNER
}

enum PatentJobStatus {
  PENDING
  RUNNING
  PAUSED
  SUCCEEDED
  FAILED
}

enum PatentImportDuplicatePolicy {
  SKIP
  OVERWRITE
}

enum PatentImportRowStatus {
  PENDING
  VALID
  INVALID
  SUCCEEDED
  FAILED
  SKIPPED
}

enum PatentOwnerClaimSource {
  PLATFORM_IMPORT
  USER_CLAIM
  ADMIN_ASSIGN
}

enum PatentClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  phone      String?  @unique
  nickname   String?
  avatarUrl  String?  @map("avatar_url")
  wechatOpenid String? @unique @map("wechat_openid")
  role       UserRole
  regionCode String?  @map("region_code")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  region Region? @relation(fields: [regionCode], references: [code])

  verifications         UserVerification[] @relation("UserVerification_User")
  reviewedVerifications UserVerification[] @relation("UserVerification_Reviewer")
  techManagerProfile    TechManagerProfile?

  listings       Listing[] @relation("Listing_Seller")
  achievements   Achievement[] @relation("Achievement_Publisher")
  orders         Order[]   @relation("Order_Buyer")
  assignedOrders Order[]   @relation("Order_AssignedCs")

  listingAuditLogs     ListingAuditLog[]     @relation("ListingAuditLog_Reviewer")
  listingFavorites     ListingFavorite[]
  achievementFavorites AchievementFavorite[]
  listingConsultEvents ListingConsultEvent[]
  listingBatchJobs     ListingBatchJob[]     @relation("ListingBatchJob_Operator")
  listingImportJobs    ListingImportJob[]    @relation("ListingImportJob_Operator")
  userTagScores        UserTagScore[]

  conversationsAsBuyer     Conversation[]            @relation("Conversation_Buyer")
  conversationsAsSeller    Conversation[]            @relation("Conversation_Seller")
  conversationParticipants ConversationParticipant[]
  sentMessages             ConversationMessage[]     @relation("ConversationMessage_Sender")
  notifications            Notification[]
  addresses                Address[]
  comments                 Comment[]

  csCases              CsCase[]       @relation("CsCase_Cs")
  caseNotes            CsCaseNote[]   @relation("CsCaseNote_Author")
  systemConfigsUpdated SystemConfig[] @relation("SystemConfig_UpdatedBy")
  auditLogs            AuditLog[]     @relation("AuditLog_Actor")
  idempotencyKeys      IdempotencyKey[]
  rbacRoles            RbacUserRole[]
  aiParseFeedbacks     AiParseFeedback[] @relation("AiParseFeedback_Actor")
  assignedMaintenanceTasks PatentMaintenanceTask[] @relation("PatentMaintenanceTask_Assignee")
  maintenanceOrdersAsApplicant PatentMaintenanceOrder[] @relation("PatentMaintenanceOrder_Applicant")
  assignedMaintenanceOrders PatentMaintenanceOrder[] @relation("PatentMaintenanceOrder_Assignee")
  maintenanceOrderEvents  PatentMaintenanceOrderEvent[] @relation("PatentMaintenanceOrderEvent_Actor")
  patentsOwned         Patent[]          @relation("Patent_Owner")
  patentImportJobs     PatentImportJob[] @relation("PatentImportJob_Operator")
  patentClaimRequests  PatentClaimRequest[] @relation("PatentClaimRequest_Applicant")
  reviewedPatentClaimRequests PatentClaimRequest[] @relation("PatentClaimRequest_Reviewer")
  conversationAgentAssignments ConversationAgent[] @relation("ConversationAgent_Operator")
  conversationAgentAssignedBy  ConversationAgent[] @relation("ConversationAgent_AssignedBy")
  techManagerBadgesAssigned TechManagerBadge[] @relation("TechManagerBadge_AssignedBy")

  @@map("users")
}

model TechManagerProfile {
  userId         String   @id @map("user_id") @db.Uuid
  intro          String?
  position       String?  @map("position")
  organization   String?  @map("organization")
  experienceLabel String? @map("experience_label")
  levelLabel     String?  @map("level_label")
  serviceDirectionsJson Json? @map("service_directions_json")
  workHighlights String?  @map("work_highlights")
  contactName    String?  @map("contact_name")
  contactPhone   String?  @map("contact_phone")
  serviceTagsJson Json?   @map("service_tags_json")
  featuredRank   Int?     @map("featured_rank")
  featuredUntil  DateTime? @map("featured_until")
  consultCount   Int      @default(0) @map("consult_count")
  dealCount      Int      @default(0) @map("deal_count")
  ratingScore    Float    @default(0) @map("rating_score")
  ratingCount    Int      @default(0) @map("rating_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  badges TechManagerBadge[]

  @@index([featuredRank])
  @@map("tech_manager_profiles")
}

model TechManagerBadgeDefinition {
  code       String                   @id
  name       String
  category   TechManagerBadgeCategory
  sortOrder  Int                      @default(0) @map("sort_order")
  enabled    Boolean                  @default(true)
  styleToken String?                  @map("style_token")
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")

  badges TechManagerBadge[]

  @@map("tech_manager_badge_definitions")
}

model TechManagerBadge {
  id                 String                 @id @default(uuid()) @db.Uuid
  techManagerUserId  String                 @map("tech_manager_user_id") @db.Uuid
  badgeCode          String                 @map("badge_code")
  assignedByUserId   String?                @map("assigned_by_user_id") @db.Uuid
  source             TechManagerBadgeSource
  assignedAt         DateTime               @default(now()) @map("assigned_at")
  expiresAt          DateTime?              @map("expires_at")
  note               String?
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  techManagerProfile TechManagerProfile     @relation(fields: [techManagerUserId], references: [userId])
  badgeDefinition    TechManagerBadgeDefinition @relation(fields: [badgeCode], references: [code])
  assignedBy         User?                  @relation("TechManagerBadge_AssignedBy", fields: [assignedByUserId], references: [id])

  @@index([techManagerUserId, assignedAt])
  @@index([badgeCode, assignedAt])
  @@map("tech_manager_badges")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  kind      NotificationKind
  title     String
  summary   String?
  source    String
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("notifications")
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  phone       String
  regionCode  String?  @map("region_code")
  addressLine String   @map("address_line")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("addresses")
}

model Comment {
  id              String             @id @default(uuid()) @db.Uuid
  contentType     CommentContentType @map("content_type")
  contentId       String             @map("content_id") @db.Uuid
  parentCommentId String?            @map("parent_comment_id") @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  text            String
  status          CommentStatus      @default(VISIBLE)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  parent  Comment? @relation("CommentParent", fields: [parentCommentId], references: [id])
  replies Comment[] @relation("CommentParent")

  @@index([contentType, contentId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("comments")
}

model Region {
  code             String      @id
  name             String
  level            RegionLevel
  parentCode       String?     @map("parent_code")
  centerLat        Float?      @map("center_lat")
  centerLng        Float?      @map("center_lng")
  industryTagsJson Json?       @map("industry_tags_json")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  parent   Region?  @relation("Region_Parent", fields: [parentCode], references: [code])
  children Region[] @relation("Region_Parent")

  users            User[]
  listings         Listing[]
  achievements     Achievement[]
  verifications    UserVerification[]

  @@map("regions")
}

model IndustryTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("industry_tags")
}

model UserVerification {
  id                         String             @id @default(uuid()) @db.Uuid
  userId                     String             @map("user_id") @db.Uuid
  verificationType           VerificationType   @map("type")
  verificationStatus         VerificationStatus @map("status")
  displayName                String             @map("display_name")
  unifiedSocialCreditCodeEnc String?            @map("unified_social_credit_code_enc")
  contactName                String?            @map("contact_name")
  contactPhone               String?            @map("contact_phone")
  regionCode                 String?            @map("region_code")
  intro                      String?
  logoFileId                 String?            @map("logo_file_id") @db.Uuid
  evidenceFileIdsJson        Json?              @map("evidence_file_ids_json")
  submittedAt                DateTime           @map("submitted_at")
  reviewedAt                 DateTime?          @map("reviewed_at")
  reviewedById               String?            @map("reviewed_by") @db.Uuid
  reviewComment              String?            @map("review_comment")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  user       User    @relation("UserVerification_User", fields: [userId], references: [id])
  reviewedBy User?   @relation("UserVerification_Reviewer", fields: [reviewedById], references: [id])
  logoFile   File?   @relation("UserVerification_LogoFile", fields: [logoFileId], references: [id])
  region     Region? @relation(fields: [regionCode], references: [code])

  @@index([userId, verificationStatus])
  @@map("user_verifications")
}

model Patent {
  id                   String              @id @default(uuid()) @db.Uuid
  jurisdiction         String              @default("CN")
  applicationNoNorm    String              @map("application_no_norm")
  applicationNoDisplay String?             @map("application_no_display")
  patentType           PatentType          @map("patent_type")
  title                String
  abstract             String?
  filingDate           DateTime?           @map("filing_date") @db.Date
  publicationDate      DateTime?           @map("publication_date") @db.Date
  grantDate            DateTime?           @map("grant_date") @db.Date
  legalStatus          String?             @map("legal_status")
  legalStatusRaw       String?             @map("legal_status_raw")
  publicationNoDisplay String?             @map("publication_no_display")
  patentNoDisplay      String?             @map("patent_no_display")
  grantPublicationNoDisplay String?        @map("grant_publication_no_display")
  transferCount        Int                 @default(0) @map("transfer_count")
  sourcePrimary        PatentSourcePrimary @default(USER) @map("source_primary")
  sourceUpdatedAt      DateTime?           @map("source_updated_at")
  ownerUserId          String?             @map("owner_user_id") @db.Uuid
  ownerClaimedAt       DateTime?           @map("owner_claimed_at")
  ownerClaimSource     PatentOwnerClaimSource? @map("owner_claim_source")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  identifiers     PatentIdentifier[]
  classifications PatentClassification[]
  parties         PatentParty[]
  listings        Listing[]
  legalEvents    PatentLegalEvent[]
  maintenanceSchedules PatentMaintenanceSchedule[]
  owner          User?                @relation("Patent_Owner", fields: [ownerUserId], references: [id])
  importRows     PatentImportJobRow[]
  claimRequests  PatentClaimRequest[]

  @@unique([jurisdiction, applicationNoNorm])
  @@index([jurisdiction, applicationNoNorm])
  @@index([ownerUserId])
  @@map("patents")
}

model PatentIdentifier {
  id          String               @id @default(uuid()) @db.Uuid
  patentId    String               @map("patent_id") @db.Uuid
  idType      PatentIdentifierType @map("id_type")
  idValueNorm String               @map("id_value_norm")
  kindCode    String?              @map("kind_code")
  dateRef     DateTime?            @map("date_ref") @db.Date

  patent Patent @relation(fields: [patentId], references: [id])

  @@unique([idType, idValueNorm])
  @@unique([idValueNorm])
  @@map("patent_identifiers")
}

model PatentClassification {
  id       String               @id @default(uuid()) @db.Uuid
  patentId String               @map("patent_id") @db.Uuid
  system   ClassificationSystem
  code     String
  isMain   Boolean              @default(false) @map("is_main")

  patent Patent @relation(fields: [patentId], references: [id])

  @@unique([patentId, system, code])
  @@map("patent_classifications")
}

model PatentParty {
  id          String          @id @default(uuid()) @db.Uuid
  patentId    String          @map("patent_id") @db.Uuid
  role        PatentPartyRole
  name        String
  countryCode String?         @map("country_code")

  patent Patent @relation(fields: [patentId], references: [id])

  @@index([patentId, role])
  @@map("patent_parties")
}

model PatentLegalEvent {
  id          String   @id @default(uuid()) @db.Uuid
  patentId    String   @map("patent_id") @db.Uuid
  eventDate   DateTime @map("event_date") @db.Date
  eventCode   String   @map("event_code")
  eventTextRaw String  @map("event_text_raw")
  source      String
  createdAt   DateTime @default(now()) @map("created_at")

  patent Patent @relation(fields: [patentId], references: [id])

  @@index([patentId, eventDate])
  @@map("patent_legal_events")
}


model File {
  id                 String               @id @default(uuid()) @db.Uuid
  url                String
  fileName           String?              @map("file_name")
  mimeType           String               @map("mime_type")
  sizeBytes          Int                  @map("size_bytes")
  ownerScope         FileOwnerScope       @map("owner_scope")
  ownerId            String               @map("owner_id") @db.Uuid
  moderationStatus   FileModerationStatus @default(NOT_REQUIRED) @map("moderation_status")
  moderationProvider String?              @map("moderation_provider")
  moderationTraceId  String?              @map("moderation_trace_id")
  moderationLabel    String?              @map("moderation_label")
  moderationReason   String?              @map("moderation_reason")
  moderationRequestedAt DateTime?         @map("moderation_requested_at")
  moderationCheckedAt DateTime?           @map("moderation_checked_at")
  createdAt          DateTime             @default(now()) @map("created_at")

  listingMedia       ListingMedia[]
  achievementMedia  AchievementMedia[]
  messageAttachments ConversationMessage[]
  milestoneEvidence  CsMilestone[]
  caseEvidences      CsCaseEvidence[]
  settlementEvidence Settlement[]
  invoiceOrders      Order[]
  contractFiles      Contract[]         @relation("Contract_File")
  maintenanceEvidenceTasks PatentMaintenanceTask[] @relation("PatentMaintenanceTask_Evidence")
  maintenanceReceiptOrders PatentMaintenanceOrder[] @relation("PatentMaintenanceOrder_ReceiptFile")
  verificationLogos  UserVerification[]    @relation("UserVerification_LogoFile")
  listingBatchJobErrorFiles ListingBatchJob[] @relation("ListingBatchJob_ErrorFile")
  listingImportJobSourceFiles ListingImportJob[] @relation("ListingImportJob_SourceFile")
  listingImportJobErrorFiles ListingImportJob[] @relation("ListingImportJob_ErrorFile")
  patentImportJobSourceFiles PatentImportJob[] @relation("PatentImportJob_SourceFile")
  patentImportJobErrorFiles PatentImportJob[] @relation("PatentImportJob_ErrorFile")
  achievementCovers  Achievement[]        @relation("Achievement_CoverFile")

  @@index([ownerScope, ownerId])
  @@index([moderationStatus, createdAt])
  @@index([moderationTraceId])
  @@map("files")
}

model Listing {
  id                 String           @id @default(uuid()) @db.Uuid
  sellerUserId       String           @map("seller_user_id") @db.Uuid
  source             ContentSource    @default(USER) @map("source")
  patentId           String?          @map("patent_id") @db.Uuid
  title              String
  summary            String?
  tradeMode          ListingTradeMode @map("trade_mode")
  licenseMode        LicenseMode?     @map("license_mode")
  priceType          PriceType        @map("price_type")
  priceAmount        Int?             @map("price_amount")
  depositAmount      Int              @map("deposit_amount")
  deliverablesJson   Json?            @map("deliverables_json")
  expectedCompletionDays Int?         @map("expected_completion_days")
  negotiableRangeFen Int?             @map("negotiable_range_fen")
  negotiableRangePercent Float?       @map("negotiable_range_percent")
  negotiableNote     String?          @map("negotiable_note")
  pledgeStatus       PledgeStatus?    @map("pledge_status")
  existingLicenseStatus ExistingLicenseStatus? @map("existing_license_status")
  encumbranceNote    String?          @map("encumbrance_note")
  regionCode         String?          @map("region_code")
  industryTagsJson   Json?            @map("industry_tags_json")
  listingTopicsJson  Json?            @map("listing_topics_json")
  proofFileIdsJson   Json?            @map("proof_file_ids_json")
  consultationRouting ConsultationRouting @default(PLATFORM) @map("consultation_routing")
  featuredLevel      FeaturedLevel    @default(NONE) @map("featured_level")
  featuredRegionCode String?          @map("featured_region_code")
  featuredRank       Int?             @map("featured_rank")
  featuredUntil      DateTime?        @map("featured_until")
  auditStatus        AuditStatus      @default(PENDING) @map("audit_status")
  status             ListingStatus    @default(DRAFT)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  seller User     @relation("Listing_Seller", fields: [sellerUserId], references: [id])
  patent Patent?  @relation(fields: [patentId], references: [id])
  region Region?  @relation(fields: [regionCode], references: [code])

  media         ListingMedia[]
  auditLogs     ListingAuditLog[]
  stats         ListingStats?
  favorites     ListingFavorite[]
  consultEvents ListingConsultEvent[]
  orders        Order[]
  conversations Conversation[]
  batchJobItems ListingBatchJobItem[]
  importJobRows ListingImportJobRow[]

  @@index([auditStatus, status])
  @@index([status, auditStatus, createdAt])
  @@index([regionCode])
  @@map("listings")
}

model Achievement {
  id                   String              @id @default(uuid()) @db.Uuid
  publisherUserId      String              @map("publisher_user_id") @db.Uuid
  source               ContentSource       @default(USER)
  externalId           String?             @unique @map("external_id")
  sourceRawCategory    String?             @map("source_raw_category")
