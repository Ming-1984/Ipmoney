{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": "../../",
    "paths": {
      "@ipmoney/shared": ["packages/shared/index.d.ts"],
      "@ipmoney/shared/*": ["packages/shared/*"]
    },
    "outDir": "./dist",
    "rootDir": "./src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src"]
}
