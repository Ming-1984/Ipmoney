  Trading --> PG
  ServiceDesk --> PG
  OpsDomain --> PG
  Common --> PG

  APIGW --> Redis
  Trading --> Redis
  ServiceDesk --> Redis
  OpsDomain --> Redis

  Trading --> Upload
