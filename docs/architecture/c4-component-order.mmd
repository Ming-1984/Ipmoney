flowchart TB
  subgraph Entry[接口与鉴权]
    direction LR
    Controller[OrdersController<br/>用户端 + 管理端订单接口]
    Guard[BearerAuthGuard / VerifiedUserGuard<br/>权限校验]
  end

  subgraph AppService[应用服务：OrdersService]
    direction TB
    Validation[参数校验与幂等控制<br/>page/pageSize/status/idempotency-key]
    StateMachine[订单状态机<br/>DEPOSIT_PENDING -> COMPLETED]
    PaymentIntent[支付意图编排<br/>订金/尾款]
    RefundEngine[退款规则引擎<br/>自动退 / 人工审核]
    SettlementEngine[结算引擎<br/>佣金计算 + 手工放款确认]
    InvoiceEngine[发票流程<br/>申请/开具/绑定/撤销]
    NotifyAdapter[通知适配器<br/>NotificationsService]
    AuditAdapter[审计适配器<br/>AuditLogService]
    ConfigAdapter[规则适配器<br/>ConfigService]
    WechatPayAdapter[微信支付适配器<br/>WechatPayClient]
  end

  subgraph Repo[持久化层（Prisma）]
    direction LR
    OrdersRepo[(orders)]
    PaymentsRepo[(payments)]
    RefundRepo[(refund_requests)]
    CasesRepo[(cs_cases / cs_milestones)]
    SettlementRepo[(settlements)]
    InvoiceRepo[(files + order.invoice_*)]
    IdempotencyRepo[(idempotency_keys)]
    AuditRepo[(audit_logs)]
  end

  subgraph Collaborators[协作模块]
    direction LR
    ConfigModule[ConfigModule]
    NotifModule[NotificationsModule]
  end

  Controller --> Guard
  Guard --> Validation

  Validation --> StateMachine
  Validation --> PaymentIntent
  Validation --> RefundEngine
  Validation --> SettlementEngine
  Validation --> InvoiceEngine

  PaymentIntent --> WechatPayAdapter
  RefundEngine --> StateMachine
  SettlementEngine --> StateMachine
  InvoiceEngine --> StateMachine

  StateMachine --> OrdersRepo
  PaymentIntent --> PaymentsRepo
  RefundEngine --> RefundRepo
  RefundEngine --> CasesRepo
  SettlementEngine --> SettlementRepo
  InvoiceEngine --> InvoiceRepo
  Validation --> IdempotencyRepo

  AuditAdapter --> AuditRepo
  StateMachine --> AuditAdapter
  PaymentIntent --> AuditAdapter
  RefundEngine --> AuditAdapter
  SettlementEngine --> AuditAdapter
  InvoiceEngine --> AuditAdapter

  StateMachine --> NotifyAdapter
  RefundEngine --> NotifyAdapter
  SettlementEngine --> NotifyAdapter
  InvoiceEngine --> NotifyAdapter

  NotifyAdapter --> NotifModule
  ConfigAdapter --> ConfigModule
  SettlementEngine --> ConfigAdapter
  RefundEngine --> ConfigAdapter


