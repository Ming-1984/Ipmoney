%%{init: {'theme':'base','flowchart': {'htmlLabels': true},'themeVariables': {'fontFamily': 'Inter, Microsoft YaHei, sans-serif','lineColor':'#64748B','primaryTextColor':'#0F172A','primaryBorderColor':'#CBD5E1','primaryColor':'#F8FAFC'}}}%%
flowchart TD
  Entry[用户进入客服中心<br/>我的 → 客服中心] --> Support[帮助与反馈<br/>/subpackages/support/index]

  Support -->|常见问题| FaqList[FAQ 列表<br/>/subpackages/support/faq/index]
  Support -->|在线客服会话| OpenSupport[POST /support/conversations]
  Support -->|电话客服| Contact[联系客服页<br/>/subpackages/support/contact/index]
  Support -->|意见反馈| Feedback[填写反馈内容]
  Support -->|交易规则| Rules[交易规则页<br/>/subpackages/trade-rules/index]

  FaqList --> FaqDetail[FAQ 详情<br/>/subpackages/support/faq/detail/index]
  FaqDetail -->|进入在线客服| OpenSupport

  Contact --> ApiConfig[GET /public/config/customer-service]
  ApiConfig --> Phone[展示热线号码]
  Phone --> Call[Taro.makePhoneCall]
  Contact -->|在线客服会话| OpenSupport

  Feedback --> OpenSupport
  OpenSupport --> SupportConv[返回 conversationId]
  Feedback --> SendFeedback[POST /conversations/:conversationId/messages]
  SupportConv --> ChatPage[聊天页<br/>/subpackages/messages/chat/index]
  SendFeedback --> ChatPage

  OrderDetail[订单详情<br/>/subpackages/orders/detail/index] -->|争议沟通| OpenDispute[POST /orders/:orderId/dispute-conversations]
  OpenDispute --> DisputeConv[返回 conversationId]
  DisputeConv --> ChatPage

  ChatPage --> MsgIndex[消息页<br/>/pages/messages/index]
  ChatPage --> AdminInbox[后台会话中心<br/>/conversations/platform]
  AdminInbox --> Assign[POST /admin/conversations/:conversationId/agents]
  AdminInbox --> Reply[POST /conversations/:conversationId/messages]
