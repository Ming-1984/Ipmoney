    Notify([短信/邮件通道])
    Storage([对象存储/CDN<br/>附件与媒体分发])
    AI([AI 服务提供方<br/>解析/智能体，P1])
  end

  Buyer --> MP
  Seller --> MP
  Buyer --> H5
  Seller --> H5
  CS --> Admin
