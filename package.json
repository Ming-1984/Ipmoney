{
  "name": "ipmoney",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "powershell -ExecutionPolicy Bypass -File scripts/download-local-banner.ps1",
    "dev": "turbo run dev --no-daemon --parallel --filter=mock-api --filter=client --filter=admin-web",
    "predev:all": "powershell -ExecutionPolicy Bypass -File scripts/download-local-banner.ps1",
    "dev:all": "turbo run dev --no-daemon --parallel",
    "dev:infra": "docker compose up -d",
    "dev:api": "docker compose up -d && pnpm -C apps/api dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier -w .",
    "openapi:lint": "redocly lint docs/api/openapi.yaml",
    "openapi:preview": "redocly preview-docs docs/api/openapi.yaml --port 8080",
    "openapi:types": "openapi-typescript docs/api/openapi.yaml -o packages/api-types/index.d.ts",
    "mock": "pnpm -C apps/mock-api dev",
    "check:weapp-budget": "node scripts/check-weapp-bundle-budget.mjs",
    "check:h5-budget": "node scripts/check-h5-bundle-budget.mjs",
    "audit:ledger": "node scripts/audit-vulnerability-ledger.mjs",
    "check:vulnerability-baseline": "node scripts/check-vulnerability-baseline.mjs",
    "update:vulnerability-baseline": "node scripts/update-vulnerability-baseline.mjs",
    "matrix:page-api-test": "node scripts/build-page-api-test-matrix.mjs",
    "scan:banned-words": "node scripts/scan-banned-words.mjs",
    "listing:region-backfill": "node scripts/run-with-env.mjs -- node scripts/listing-region-backfill.mjs",
    "check:prod-env": "node scripts/run-with-env.mjs -- node scripts/check-prod-env.mjs",
    "check:docs-links": "node scripts/check-doc-links.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.0",
    "@stoplight/prism-cli": "^5.14.1",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "miniprogram-automator": "^0.12.1",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.5.1",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "effect": "^3.20.0",
      "minimatch@<3.1.5": "3.1.5",
      "minimatch@>=5.0.0 <5.1.9": "5.1.9",
      "multer": "^2.1.1"
    }
  }
}
