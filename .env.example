# Copy to `.env` and fill values. Do not commit real secrets.

NODE_ENV=development
PORT=3000
BASE_URL=https://api.ipmoney.cn
ADMIN_BASE_URL=https://admin.ipmoney.cn
H5_BASE_URL=https://ipmoney.cn
WEB_BASE_URL=https://www.ipmoney.cn
TRUST_PROXY=false
# Comma-separated allowed Origins, or "*" to allow any.
CORS_ORIGINS=https://ipmoney.cn,https://www.ipmoney.cn,https://admin.ipmoney.cn
UPLOAD_DIR=./uploads
PUBLIC_HOST_WHITELIST=api.ipmoney.cn
FILE_TEMP_TOKEN_SECRET=change-me
FILE_TEMP_TOKEN_TTL_SECONDS=900
FILE_WATERMARK_TEXT=Ipmoney Preview

# Database / Cache
DATABASE_URL=postgresql://ipmoney:ipmoney@127.0.0.1:5433/ipmoney
POSTGRES_PORT=5433
REDIS_URL=redis://127.0.0.1:6380
REDIS_PORT=6380

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=7200
SMS_CODE_SECRET=change-me

# WeChat Mini Program Login
WX_MP_APPID=wxa053408fad6ab1df
# Optional alias (runtime compatibility): WX_MP_ID
WX_MP_ID=wxa053408fad6ab1df
WX_MP_SECRET=

# WeChat Pay v3
WX_PAY_MCHID=
WX_PAY_MCH_CERT_SERIAL_NO=
WX_PAY_API_V3_KEY=
WX_PAY_MCH_PRIVATE_KEY=
WX_PAY_PLATFORM_CERT_SERIAL_NO=
WX_PAY_PLATFORM_CERT=
WX_PAY_PLATFORM_CERTS=
WX_PAY_NOTIFY_URL=https://api.ipmoney.cn/webhooks/wechatpay/notify
# Optional for local non-prod testing when user openid is unavailable
WX_PAY_TEST_OPENID=

# S3 Compatible Storage (MinIO/COS/OSS)
S3_ENDPOINT=http://127.0.0.1:9002
S3_REGION=ap-guangzhou
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=ipmoney
S3_PUBLIC_BASE_URL=http://127.0.0.1:9002/ipmoney
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003

# Seed (base vs demo)
SEED_BASE_DATA=true
SEED_DEMO_DATA=false

# Feature Flags
ENABLE_USER_H5=true
ENABLE_H5_PAYMENT=false
ENABLE_AUTO_PAYOUT=false
REQUEST_LOG_ENABLED=true
DEMO_AUTH_ENABLED=false
DEMO_AUTH_ALLOW_UUID_TOKENS=false
DEMO_ADMIN_TOKEN=
DEMO_USER_TOKEN=
DEMO_ADMIN_ID=804b7a04-aafe-409a-bee4-e84f953cb4c0
DEMO_USER_ID=8c592d03-c1c1-40be-8d62-64ce71ac7606
DEMO_ADMIN_NICKNAME=平台管理员
DEMO_USER_NICKNAME=演示用户
DEMO_ADMIN_PHONE=13900000000
DEMO_USER_PHONE=13800138000
DEMO_ADMIN_REGION_CODE=110000
DEMO_USER_REGION_CODE=110000
DEMO_PAYMENT_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=120

# Frontend/Admin API Base URL (release build must be non-localhost https domain)
TARO_APP_API_BASE_URL=https://api.ipmoney.cn
VITE_API_BASE_URL=https://api.ipmoney.cn

# SMS (Aliyun, for `/auth/sms/send` + `/auth/sms/verify`)
# Production recommendation:
# SMS_PROVIDER=ALIYUN
# SMS_SIGN_NAME=<your sms sign name>
# SMS_TEMPLATE_ID=<sms template id>
# SMS_ACCESS_KEY=<aliyun access key id>
# SMS_SECRET_KEY=<aliyun access key secret>
SMS_PROVIDER=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=
# Backward compatibility (legacy names)
SMS_TEMPLATE_ID_LOGIN=
# Optional (fallback for BIND_PHONE purpose to login template when empty)
SMS_TEMPLATE_ID_BIND_PHONE=
# Optional alternate key names (legacy compatibility)
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_API_KEY=
SMS_API_SECRET=
# Optional Aliyun overrides
SMS_ALIYUN_ENDPOINT=
SMS_REGION_ID=cn-hangzhou
SMS_TEMPLATE_PARAM_KEY=code

# mock-api upstream (optional: route some prefixes to real API)
UPSTREAM_API_BASE_URL=
UPSTREAM_PATH_PREFIXES=/files,/patents
UPSTREAM_FALLBACK_STATUSES=404,501
