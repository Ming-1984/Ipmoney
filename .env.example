# Copy to `.env` and fill values. Do not commit real secrets.

NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
UPLOAD_DIR=./uploads
PUBLIC_HOST_WHITELIST=localhost:3000
FILE_TEMP_TOKEN_SECRET=change-me
FILE_TEMP_TOKEN_TTL_SECONDS=900
FILE_WATERMARK_TEXT=Ipmoney Preview

# Database / Cache
DATABASE_URL=postgresql://ipmoney:ipmoney@127.0.0.1:5433/ipmoney
POSTGRES_PORT=5433
REDIS_URL=redis://127.0.0.1:6380
REDIS_PORT=6380

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=7200

# WeChat Mini Program Login
WX_MP_APPID=
WX_MP_SECRET=

# WeChat Pay v3
WX_PAY_MCHID=
WX_PAY_MCH_CERT_SERIAL_NO=
WX_PAY_API_V3_KEY=
WX_PAY_MCH_PRIVATE_KEY=
WX_PAY_NOTIFY_URL=

# S3 Compatible Storage (MinIO/COS/OSS)
S3_ENDPOINT=http://127.0.0.1:9002
S3_REGION=ap-guangzhou
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=ipmoney
S3_PUBLIC_BASE_URL=http://127.0.0.1:9002/ipmoney
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003

# Feature Flags
ENABLE_USER_H5=true
ENABLE_H5_PAYMENT=false
ENABLE_AUTO_PAYOUT=false
DEMO_AUTH_ENABLED=false
DEMO_AUTH_ALLOW_UUID_TOKENS=false
DEMO_ADMIN_TOKEN=
DEMO_USER_TOKEN=
DEMO_ADMIN_ID=804b7a04-aafe-409a-bee4-e84f953cb4c0
DEMO_USER_ID=8c592d03-c1c1-40be-8d62-64ce71ac7606
DEMO_ADMIN_NICKNAME=平台管理员
DEMO_USER_NICKNAME=演示用户
DEMO_ADMIN_PHONE=13900000000
DEMO_USER_PHONE=13800138000
DEMO_ADMIN_REGION_CODE=110000
DEMO_USER_REGION_CODE=110000
DEMO_PAYMENT_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=120

# mock-api upstream (optional: route some prefixes to real API)
UPSTREAM_API_BASE_URL=
UPSTREAM_PATH_PREFIXES=/files,/patents
UPSTREAM_FALLBACK_STATUSES=404,501
